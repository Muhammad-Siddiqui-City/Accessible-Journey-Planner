<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/ajp_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="88dp">

        <!-- Primary header (same style as Analytics) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/primary_header_bg"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/where_to"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/ajp_primary_foreground" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accessible_journey_planner"
                android:textSize="16sp"
                android:textColor="?attr/ajp_primary_foreground"
                android:alpha="0.9"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Search bar with icons (Lovable: magnifying glass, accessibility, mic) -->
        <LinearLayout
            android:id="@+id/search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/search_bar_pill"
            android:padding="16dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="@null"
                app:tint="?attr/ajp_muted_foreground" />
            <EditText
                android:id="@+id/search_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:hint="@string/search_placeholder"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:textSize="16sp"
                android:textColor="?attr/ajp_foreground"
                android:textColorHint="?attr/ajp_muted_foreground" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_green_man"
                android:contentDescription="@string/accessible"
                android:scaleType="fitCenter" />
            <View android:layout_width="1dp" android:layout_height="20dp" android:background="?attr/ajp_border" android:layout_marginHorizontal="8dp" />
            <!-- Wrapper gives mic a 48dp touch target so taps are not stolen by search bar -->
            <FrameLayout
                android:id="@+id/search_mic_touch"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center">
                <ImageView
                    android:id="@+id/search_mic"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:contentDescription="@string/voice_search"
                    app:tint="?attr/ajp_muted_foreground" />
            </FrameLayout>
        </LinearLayout>

        <!-- Quick actions: 3 cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">
            <LinearLayout
                android:id="@+id/card_nearby_stations"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_gradient_blue"
                android:padding="8dp"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_directions" android:contentDescription="@null" app:tint="@android:color/white" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/nearby_stations"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="2"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeStepGranularity="1sp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_live_arrivals"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_gradient_teal"
                android:padding="16dp"
                android:layout_marginHorizontal="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_charging" android:contentDescription="@null" app:tint="@android:color/white" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/popular_station"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="2"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeStepGranularity="1sp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/card_plan_journey"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_gradient_purple"
                android:padding="16dp"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_mylocation" android:contentDescription="@null" app:tint="@android:color/white" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/plan_journey" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Disruptions (live: lines serving nearby stations) -->
        <LinearLayout
            android:id="@+id/layout_disruptions_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/disruptions"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/ajp_foreground" />
                <TextView
                    android:id="@+id/tv_disruption_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="?attr/ajp_muted_foreground" />
            </LinearLayout>
            <!-- Good service card (shown when no disruptions) -->
            <LinearLayout
                android:id="@+id/good_service_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/border_left_red"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/good_service_on_local_lines"
                    android:textSize="14sp"
                    android:textColor="?attr/ajp_foreground" />
            </LinearLayout>
            <!-- Disruption Card 1 -->
            <LinearLayout
                android:id="@+id/disruption_card_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/border_left_red"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_disruption_line_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:id="@+id/tv_disruption_desc_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/ajp_foreground" />
            </LinearLayout>
            <!-- Disruption Card 2 -->
            <LinearLayout
                android:id="@+id/disruption_card_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/border_left_red"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_disruption_line_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:id="@+id/tv_disruption_desc_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/ajp_foreground" />
            </LinearLayout>
        </LinearLayout>

        <!-- Saved Routes (for offline navigation) -->
        <LinearLayout
            android:id="@+id/layout_saved_routes_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saved_routes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/ajp_foreground"
                android:layout_marginBottom="12dp" />
            <TextView
                android:id="@+id/tv_saved_routes_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_saved_routes"
                android:textSize="14sp"
                android:textColor="?attr/ajp_muted_foreground"
                android:visibility="gone" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/saved_routes_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- Nearby Stations -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nearby_stations"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/ajp_foreground" />
                <TextView
                    android:id="@+id/nearby_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all_chevron"
                    android:textSize="14sp"
                    android:textColor="?attr/ajp_foreground"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
            <!-- Cards + loading overlay: dynamic Station 1 (SWR) and Station 2 (Tube) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Card 1 (e.g. SWR) -->
                    <LinearLayout
                        android:id="@+id/nearby_station_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_elevated"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_home_station_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/ajp_foreground" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_mylocation" android:contentDescription="@null" app:tint="?attr/ajp_muted_foreground" />
                                <TextView
                                    android:id="@+id/tv_home_dist_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="14sp"
                                    android:textColor="?attr/ajp_muted_foreground"
                                    android:layout_marginStart="4dp" />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/layout_home_badges_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">
                            </LinearLayout>
                        </LinearLayout>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_next" android:contentDescription="@null" app:tint="?attr/ajp_muted_foreground" />
                    </LinearLayout>
                    <!-- Card 2 (e.g. Tube) -->
                    <LinearLayout
                        android:id="@+id/nearby_station_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/glass_card"
                        android:padding="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/tv_home_station_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/ajp_foreground" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_mylocation" android:contentDescription="@null" app:tint="?attr/ajp_muted_foreground" />
                                <TextView
                                    android:id="@+id/tv_home_dist_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="14sp"
                                    android:textColor="?attr/ajp_muted_foreground"
                                    android:layout_marginStart="4dp" />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/layout_home_badges_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">
                            </LinearLayout>
                        </LinearLayout>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_next" android:contentDescription="@null" app:tint="?attr/ajp_muted_foreground" />
                    </LinearLayout>
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/home_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- Transport Modes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/transport_modes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/ajp_foreground"
                android:layout_marginBottom="12dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">
                <LinearLayout
                    android:id="@+id/transport_tube"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:background="@drawable/card_elevated"
                    android:padding="16dp"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_train"
                        android:contentDescription="@null"
                        app:tint="?attr/ajp_foreground" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tube_rail"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/ajp_foreground" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/good_service"
                            android:textSize="14sp"
                            android:textColor="#4CAF50" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/transport_bus"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:background="@drawable/card_elevated"
                    android:padding="16dp"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_bus"
                        android:contentDescription="@null"
                        app:tint="?attr/ajp_foreground" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/buses"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/ajp_foreground" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/minor_delays"
                            android:textSize="14sp"
                            android:textColor="#CC6600" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
