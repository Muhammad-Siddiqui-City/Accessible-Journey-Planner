<?xml version="1.0" encoding="utf-8"?>
<!-- AI Generated -->
<!-- Lovable.dev: UI mockup reference -->
<!-- Suggested route card: outlined, with duration, BEST badge, crowding bar. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_route_card"
    android:padding="16dp"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Top row: Duration (15), min, BEST badge, Departure time (14:32), Depart label -->
    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/ajp_foreground"
        android:text="15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/minutes"
        android:textSize="14sp"
        android:textColor="?attr/ajp_muted_foreground"
        app:layout_constraintStart_toEndOf="@id/tvDuration"
        app:layout_constraintBottom_toBottomOf="@id/tvDuration"
        android:layout_marginStart="4dp" />

    <TextView
        android:id="@+id/tvBestBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BEST"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_badge_best"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/tvMin"
        app:layout_constraintTop_toTopOf="@id/tvDuration"
        app:layout_constraintBottom_toBottomOf="@id/tvDuration"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/tvDepartureTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?attr/ajp_foreground"
        tools:text="14:32"
        app:layout_constraintEnd_toStartOf="@id/chevron"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="4dp" />

    <ImageView
        android:id="@+id/chevron"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_media_next"
        app:tint="?attr/ajp_muted_foreground"
        android:contentDescription="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDepartLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/depart"
        android:textSize="12sp"
        android:textColor="?attr/ajp_muted_foreground"
        app:layout_constraintEnd_toEndOf="@id/tvDepartureTime"
        app:layout_constraintTop_toBottomOf="@id/tvDepartureTime" />

    <!-- Second row: Crowding icon+text, Access icon+text, Transfers text -->
    <ImageView
        android:id="@+id/iconCrowding"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/ic_menu_myplaces"
        app:tint="?attr/ajp_muted_foreground"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDepartLabel"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvCrowdingDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="?attr/ajp_foreground"
        tools:text="@string/crowding_low"
        app:layout_constraintStart_toEndOf="@id/iconCrowding"
        app:layout_constraintTop_toTopOf="@id/iconCrowding"
        app:layout_constraintBottom_toBottomOf="@id/iconCrowding"
        android:layout_marginStart="4dp" />

    <ImageView
        android:id="@+id/iconAccess"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_accessibility"
        app:tint="?attr/ajp_muted_foreground"
        android:contentDescription="@null"
        app:layout_constraintStart_toEndOf="@id/tvCrowdingDetail"
        app:layout_constraintTop_toTopOf="@id/iconCrowding"
        android:layout_marginStart="12dp" />

    <TextView
        android:id="@+id/tvAccessDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/step_free"
        android:textSize="14sp"
        android:textColor="?attr/ajp_foreground"
        app:layout_constraintStart_toEndOf="@id/iconAccess"
        app:layout_constraintTop_toTopOf="@id/iconCrowding"
        app:layout_constraintBottom_toBottomOf="@id/iconCrowding"
        android:layout_marginStart="4dp" />

    <TextView
        android:id="@+id/tvTransfers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="?attr/ajp_muted_foreground"
        tools:text="@string/zero_transfers"
        app:layout_constraintStart_toEndOf="@id/tvAccessDetail"
        app:layout_constraintTop_toTopOf="@id/iconCrowding"
        app:layout_constraintBottom_toBottomOf="@id/iconCrowding"
        android:layout_marginStart="8dp" />

    <!-- Third row: Line badges (VIC, PIC, etc.) -->
    <LinearLayout
        android:id="@+id/lineBadgesContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconCrowding"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/badgeLine1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/line_victoria"
            android:text="VIC"
            android:textColor="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp" />
        <TextView
            android:id="@+id/badgeLine2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/line_piccadilly"
            android:text="PIC"
            android:textColor="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRouteSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="14sp"
        android:textColor="?attr/ajp_muted_foreground"
        tools:text="King's Cross St. Pancras → Battersea Power Station"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lineBadgesContainer"
        android:layout_marginTop="8dp" />

    <!-- Bottom: CROWDING label + progress bar -->
    <View
        android:id="@+id/dividerCrowding"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/ajp_border"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lineBadgesContainer"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/tvCrowdingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/crowding"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="?attr/ajp_muted_foreground"
        android:letterSpacing="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerCrowding"
        android:layout_marginTop="8dp" />

    <ProgressBar
        android:id="@+id/progressBarCrowding"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:max="100"
        android:progress="25"
        android:progressDrawable="@drawable/progress_crowding"
        android:indeterminate="false"
        app:layout_constraintStart_toEndOf="@id/tvCrowdingLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvCrowdingLabel"
        app:layout_constraintBottom_toBottomOf="@id/tvCrowdingLabel"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/tvLiftDisruptionWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/lift_disruption_warning"
        android:textSize="11sp"
        android:textColor="#D32F2F"
        android:visibility="gone"
        android:maxLines="3"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCrowdingLabel"
        android:layout_marginTop="4dp" />
    <TextView
        android:id="@+id/tvCrowdingWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/crowding_warning"
        android:textSize="11sp"
        android:textColor="#D32F2F"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLiftDisruptionWarning"
        android:layout_marginTop="2dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
